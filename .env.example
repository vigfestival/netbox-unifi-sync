# netbox-unifi-sync — environment variables
#
# NORMAL CONFIGURATION IS DONE IN THE NETBOX UI:
#   Plugins -> UniFi Sync -> Settings        (global behaviour)
#   Plugins -> UniFi Sync -> Controllers     (UniFi URL + credentials, masked)
#   Plugins -> UniFi Sync -> Site Mappings   (UniFi <-> NetBox site names)
#
# The values below are the environment variables the sync ENGINE honours. During
# a normal run they are populated automatically from the database-backed Settings
# above, so you do NOT need this file for day-to-day use. They are documented here
# for advanced / headless / CLI scenarios where you want to override behaviour for
# a single `manage.py netbox_unifi_sync_run` invocation.
#
# The plugin runs INSIDE NetBox, so there is no separate NetBox URL/token to set —
# it talks to NetBox through the in-process ORM. NETBOX_URL/NETBOX_VERIFY_SSL exist
# only for legacy/standalone tooling and are unused by the in-NetBox plugin.

# --- NetBox-side behaviour ----------------------------------------------------
NETBOX_IMPORT_TENANT=VF                 # tenant new objects are created under
NETBOX_VRF_MODE=existing                # none | existing | create
NETBOX_DEFAULT_VRF=                     # VRF name used for all sites (optional)
NETBOX_SERIAL_MODE=mac                  # mac | unifi | id | none
NETBOX_DEVICE_STATUS=planned            # status for newly created devices
NETBOX_CLEANUP=false                    # true = delete stale UniFi-owned objects

# --- What to sync -------------------------------------------------------------
SYNC_VLANS=true
SYNC_WLANS=true
SYNC_CABLES=true
SYNC_PREFIXES=true
SYNC_DHCP_RANGES=true
SYNC_CLIENT_IPS=false
SYNC_STALE_CLEANUP=true
DHCP_AUTO_DISCOVER=true
DEFAULT_GATEWAY=
DEFAULT_DNS=

# --- Asset tags ---------------------------------------------------------------
UNIFI_ASSET_TAG_ENABLED=true
UNIFI_ASSET_TAG_UPPERCASE=true
# JSON list of regexes; first match wins, capture group is the extracted tag
UNIFI_ASSET_TAG_PATTERNS=["[-_]?(A?ID\\d+)$"]

# --- UniFi credentials (prefer the Controllers UI; these are for CLI only) ----
# UNIFI_API_KEY=
# UNIFI_API_KEY_HEADER=X-API-KEY
# UNIFI_USERNAME=
# UNIFI_PASSWORD=
# UNIFI_MFA_SECRET=
UNIFI_VERIFY_SSL=true
UNIFI_USE_SITE_MAPPING=true

# --- Community device-spec cache ----------------------------------------------
UNIFI_SPECS_AUTO_REFRESH=false
UNIFI_SPECS_INCLUDE_STORE=false
UNIFI_SPECS_WRITE_CACHE=false
# UNIFI_SPECS_FILE=/var/tmp/netbox-unifi-sync/ubiquiti_device_specs.json
